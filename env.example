# ============================================
# ReVoice Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# Anthropic API Key (required for content generation)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (required for Whisper transcription)
# Get from: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# NextAuth Secret (required for authentication)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# App URL (set to your deployment URL in production)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth (optional - for GitHub sign-in)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

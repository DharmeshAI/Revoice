# OpenAI API Key (required for Whisper transcription)
# Get from: https://platform.openai.com
OPENAI_API_KEY=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

# NextAuth Secret (required for authentication)
# Generate with: openssl rand -base64 32
